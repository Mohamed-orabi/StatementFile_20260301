@page "/"
@attribute [Authorize]
@inject IBankProductConfigApiClient BankConfigApi
@inject IStatementGenerationApiClient GenerationApi

<PageTitle>Statement Generation — StatementFile</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Statement Generation</h4>
    <a href="/bank-config" class="btn btn-outline-primary btn-sm">⚙ Bank Configuration</a>
</div>

@if (!string.IsNullOrEmpty(LoadError))
{
    <div class="alert alert-danger py-2">@LoadError</div>
}

@if (Results.Count > 0)
{
    int successCount = Results.Count(r => r.Success);
    <div class="alert @(successCount == Results.Count ? "alert-success" : "alert-warning") mb-3">
        <strong>@successCount of @Results.Count ran successfully.</strong>
        <ul class="mb-0 mt-1">
            @foreach (var r in Results)
            {
                <li class="@(r.Success ? "" : "text-danger")">
                    Config @r.ConfigId:
                    @if (r.Success)
                    {
                        <span>@r.FilesGenerated file(s) → @r.OutputDirectory</span>
                        <small class="text-muted ms-1">(@r.EmailsSent emails, @r.StatementsCount statements)</small>
                    }
                    else
                    {
                        <span>@r.Error</span>
                    }
                </li>
            }
        </ul>
    </div>
}

<form method="post" @formname="generate">
    <AntiforgeryToken />

    <div class="row g-2 mb-3 align-items-end">
        <div class="col-auto">
            <label class="form-label mb-1">Statement Date</label>
            <input type="date" name="StatementDate" class="form-control"
                   value="@(FormData?.StatementDate ?? DateTime.Today.ToString("yyyy-MM-dd"))" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-success">Generate Selected</button>
        </div>
    </div>

    <div class="table-responsive" style="max-height:600px;overflow-y:auto">
        <table class="table table-sm table-hover align-middle">
            <thead class="table-light sticky-top">
                <tr>
                    <th style="width:36px"></th>
                    <th>Bank / Product</th>
                    <th>Formatter</th>
                    <th>Branch</th>
                    <th>Type</th>
                    <th>Active</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cfg in Catalog)
                {
                    <tr class="@(cfg.IsActive ? "" : "text-muted")">
                        <td>
                            <input type="checkbox" name="SelectedIds" value="@cfg.Id"
                                   class="form-check-input"
                                   checked="@cfg.IsActive" />
                        </td>
                        <td>
                            <strong>@cfg.BankName</strong>
                            <small class="text-muted ms-1">@cfg.StatementTypeSuffix</small>
                            <br /><small class="text-muted">@cfg.BankFullName · @cfg.CardProduct</small>
                        </td>
                        <td><span class="badge bg-secondary">@cfg.FormatterKey</span></td>
                        <td><small>@cfg.BranchCode</small></td>
                        <td><small>@((StatementOutputType)cfg.OutputType)</small></td>
                        <td>
                            @if (cfg.IsActive)
                            {
                                <span class="badge bg-success">Yes</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">No</span>
                            }
                        </td>
                    </tr>
                }
                @if (Catalog.Count == 0 && string.IsNullOrEmpty(LoadError))
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">No products found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</form>

@code {
    [SupplyParameterFromForm(FormName = "generate")]
    private GenerationFormModel FormData { get; set; }

    private List<BankProductConfigDto> Catalog { get; } = new();
    private string LoadError { get; set; }
    private List<RunResultRow> Results { get; } = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var items = await BankConfigApi.GetAllAsync();
            Catalog.AddRange(items);
        }
        catch (Exception ex)
        {
            LoadError = $"Could not load bank configurations: {ex.Message}";
        }

        if (FormData == null) return;

        DateTime date = DateTime.TryParse(FormData.StatementDate, out var d) ? d : DateTime.Today;

        foreach (int id in FormData.SelectedIds ?? Array.Empty<int>())
        {
            try
            {
                var result = await GenerationApi.RunAsync(new StatementRunRequest
                {
                    ConfigId      = id,
                    StatementDate = date,
                });

                Results.Add(new RunResultRow
                {
                    ConfigId        = id,
                    Success         = result.Success,
                    FilesGenerated  = result.FilesGenerated,
                    OutputDirectory = result.OutputDirectory,
                    EmailsSent      = result.EmailsSent,
                    StatementsCount = result.StatementsCount,
                    Error           = result.Error,
                });
            }
            catch (Exception ex)
            {
                Results.Add(new RunResultRow { ConfigId = id, Success = false, Error = ex.Message });
            }
        }
    }

    private sealed class GenerationFormModel
    {
        public int[]  SelectedIds   { get; set; } = Array.Empty<int>();
        public string StatementDate { get; set; } = DateTime.Today.ToString("yyyy-MM-dd");
    }

    private sealed class RunResultRow
    {
        public int    ConfigId        { get; set; }
        public bool   Success         { get; set; }
        public int    FilesGenerated  { get; set; }
        public int    EmailsSent      { get; set; }
        public int    StatementsCount { get; set; }
        public string OutputDirectory { get; set; } = string.Empty;
        public string Error           { get; set; } = string.Empty;
    }
}
