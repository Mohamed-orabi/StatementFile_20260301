@page "/merchant"
@attribute [Authorize]
@inject IMerchantStatementApiClient MerchantApi
@inject IHttpContextAccessor HttpContextAccessor

<PageTitle>Merchant Statement — StatementFile</PageTitle>

<h4 class="mb-3">Merchant Statement</h4>

<div class="row">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">Process Merchant XML</div>
            <div class="card-body">

                @if (!string.IsNullOrEmpty(ResultMessage))
                {
                    <div class="alert @(ResultIsError ? "alert-danger" : "alert-success") py-2">
                        @ResultMessage
                    </div>
                }

                <form method="post" enctype="multipart/form-data" @formname="merchant">
                    <AntiforgeryToken />

                    <div class="mb-3">
                        <label class="form-label">Bank Full Name</label>
                        <input name="BankFullName" class="form-control"
                               placeholder="e.g. United Bank for Africa"
                               value="@(FormData?.BankFullName ?? string.Empty)" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Bank Name (code)</label>
                        <input name="BankName" class="form-control"
                               placeholder="e.g. UBA"
                               value="@(FormData?.BankName ?? string.Empty)" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Bank Code</label>
                        <input name="BankCode" class="form-control"
                               placeholder="e.g. UBA01"
                               value="@(FormData?.BankCode ?? string.Empty)" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Processing Date</label>
                        <input type="date" name="ProcessingDate" class="form-control"
                               value="@(FormData?.ProcessingDate ?? DateTime.Today.ToString("yyyy-MM-dd"))" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Merchant XML File</label>
                        <input type="file" name="XmlFile" class="form-control" accept=".xml" />
                    </div>

                    <button type="submit" class="btn btn-primary w-100">Process Merchant Statement</button>
                </form>
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromForm(FormName = "merchant")]
    private MerchantFormModel FormData { get; set; }

    private string ResultMessage { get; set; } = string.Empty;
    private bool   ResultIsError { get; set; }

    private const long MaxFileBytes = 50 * 1024 * 1024; // 50 MB

    protected override async Task OnInitializedAsync()
    {
        if (FormData == null) return;

        var ctx     = HttpContextAccessor.HttpContext;
        var xmlFile = ctx?.Request.Form.Files["XmlFile"];

        if (xmlFile == null || xmlFile.Length == 0)
        {
            ResultIsError = true;
            ResultMessage = "Please select an XML file.";
            return;
        }

        if (xmlFile.Length > MaxFileBytes)
        {
            ResultIsError = true;
            ResultMessage = $"File is too large (max {MaxFileBytes / 1024 / 1024} MB).";
            return;
        }

        try
        {
            byte[] bytes;
            using (var ms = new MemoryStream())
            {
                await xmlFile.CopyToAsync(ms);
                bytes = ms.ToArray();
            }

            var result = await MerchantApi.ProcessAsync(new MerchantProcessRequest
            {
                BankFullName     = FormData.BankFullName   ?? string.Empty,
                BankName         = FormData.BankName       ?? string.Empty,
                BankCode         = FormData.BankCode       ?? string.Empty,
                ProcessingDate   = DateTime.TryParse(FormData.ProcessingDate, out var d) ? d : DateTime.Today,
                XmlContentBase64 = Convert.ToBase64String(bytes),
            });

            ResultIsError = !result.Success;
            ResultMessage = result.Message ?? (result.Success ? "Processed successfully." : "Processing failed.");
        }
        catch (Exception ex)
        {
            ResultIsError = true;
            ResultMessage = $"Unexpected error: {ex.Message}";
        }
    }

    private sealed class MerchantFormModel
    {
        public string BankFullName   { get; set; } = string.Empty;
        public string BankName       { get; set; } = string.Empty;
        public string BankCode       { get; set; } = string.Empty;
        public string ProcessingDate { get; set; } = DateTime.Today.ToString("yyyy-MM-dd");
    }
}
