@page "/bank-config"
@attribute [Authorize]
@inject IBankProductConfigApiClient BankConfigApi
@inject NavigationManager Nav

<PageTitle>Bank Configuration — StatementFile</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Bank / Product Configuration</h4>
    <div class="d-flex gap-2">
        <a href="/bank-config?mode=create" class="btn btn-success btn-sm">+ New Configuration</a>
        <a href="/" class="btn btn-outline-secondary btn-sm">← Back to Generation</a>
    </div>
</div>

@* ── Create / Edit form ────────────────────────────────────────────────── *@
@if (Mode == "create" || Mode == "edit")
{
    <div class="card mb-4 shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>@(Id == 0 ? "New Configuration" : $"Edit Configuration #{Id}")</span>
            <a href="/bank-config" class="btn-close" title="Cancel"></a>
        </div>
        <div class="card-body">
            @if (!string.IsNullOrEmpty(FormError))
            {
                <div class="alert alert-danger py-1 mb-2">@FormError</div>
            }
            <form method="post" @formname="config-form">
                <AntiforgeryToken />
                <input type="hidden" name="EditingId" value="@Id" />

                <div class="row g-2">
                    <div class="col-12"><h6 class="mb-1 text-muted">Identity</h6></div>
                    <div class="col-md-2">
                        <label class="form-label form-label-sm">Branch Code</label>
                        <input type="number" name="BranchCode" class="form-control form-control-sm"
                               value="@DisplayForm.BranchCode" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label form-label-sm">Bank Code</label>
                        <input name="BankName" class="form-control form-control-sm" placeholder="UBA"
                               value="@DisplayForm.BankName" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label form-label-sm">Bank Full Name</label>
                        <input name="BankFullName" class="form-control form-control-sm"
                               value="@DisplayForm.BankFullName" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label form-label-sm">Card Product</label>
                        <input name="CardProduct" class="form-control form-control-sm" placeholder="UBACR"
                               value="@DisplayForm.CardProduct" />
                    </div>

                    <div class="col-12 mt-2"><h6 class="mb-1 text-muted">Output</h6></div>
                    <div class="col-md-4">
                        <label class="form-label form-label-sm">Output Type</label>
                        <select name="OutputType" class="form-select form-select-sm">
                            @foreach (var v in Enum.GetValues<StatementOutputType>())
                            {
                                <option value="@((int)v)" selected="@(DisplayForm.OutputType == (int)v)">@v</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label form-label-sm">Formatter Key</label>
                        <input name="FormatterKey" class="form-control form-control-sm" placeholder="HTML_UBA"
                               value="@DisplayForm.FormatterKey" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label form-label-sm">Stmt Suffix</label>
                        <input name="StatementTypeSuffix" class="form-control form-control-sm" placeholder="CR"
                               value="@DisplayForm.StatementTypeSuffix" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label form-label-sm">Sched. Day</label>
                        <input type="number" min="1" max="31" name="ScheduledDay" class="form-control form-control-sm"
                               value="@DisplayForm.ScheduledDay" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label form-label-sm">Card Type</label>
                        <select name="CardType" class="form-select form-select-sm">
                            @foreach (var v in Enum.GetValues<CardType>())
                            {
                                <option value="@((int)v)" selected="@(DisplayForm.CardType == (int)v)">@v</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label form-label-sm">Statement Type</label>
                        <select name="StatementType" class="form-select form-select-sm">
                            @foreach (var v in Enum.GetValues<StatementType>())
                            {
                                <option value="@((int)v)" selected="@(DisplayForm.StatementType == (int)v)">@v</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label form-label-sm">Field Separator</label>
                        <input name="FieldSeparator" class="form-control form-control-sm" placeholder=","
                               value="@DisplayForm.FieldSeparator" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label form-label-sm">Sort Order</label>
                        <input type="number" name="SortOrder" class="form-control form-control-sm"
                               value="@DisplayForm.SortOrder" />
                    </div>

                    <div class="col-12 mt-2"><h6 class="mb-1 text-muted">Flags</h6></div>
                    <div class="col-md-3">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="fAppend" name="AppendMode"
                                   checked="@DisplayForm.AppendMode" />
                            <label class="form-check-label" for="fAppend">Append Mode</label>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="fCorp" name="UseCorporateAccountNumber"
                                   checked="@DisplayForm.UseCorporateAccountNumber" />
                            <label class="form-check-label" for="fCorp">Corporate Account No.</label>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="fActive" name="IsActive"
                                   checked="@DisplayForm.IsActive" />
                            <label class="form-check-label" for="fActive">Active</label>
                        </div>
                    </div>

                    <div class="col-12 mt-2"><h6 class="mb-1 text-muted">Processing Modes</h6></div>
                    <div class="col-12">
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var mode in NonStandardModes)
                            {
                                <div class="form-check form-check-inline mb-0">
                                    <input class="form-check-input" type="checkbox"
                                           id="pm_@mode" name="SelectedModes" value="@((long)mode)"
                                           checked="@(((ProcessingMode)DisplayForm.ProcessingModes).HasFlag(mode))" />
                                    <label class="form-check-label" for="pm_@mode"><small>@mode</small></label>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="col-12 mt-2"><h6 class="mb-1 text-muted">Oracle Conditions</h6></div>
                    <div class="col-12">
                        <label class="form-label form-label-sm">Reward Contract Condition</label>
                        <input name="RewardContractCondition" class="form-control form-control-sm"
                               placeholder="'New Reward Contract'" value="@DisplayForm.RewardContractCondition" />
                    </div>
                    <div class="col-12">
                        <label class="form-label form-label-sm">Installment Contract Condition</label>
                        <input name="InstallmentContractCondition" class="form-control form-control-sm"
                               value="@DisplayForm.InstallmentContractCondition" />
                    </div>

                    <div class="col-12 mt-2"><h6 class="mb-1 text-muted">PDF (optional)</h6></div>
                    <div class="col-md-6">
                        <label class="form-label form-label-sm">Report Template Name</label>
                        <input name="ReportTemplateName" class="form-control form-control-sm"
                               value="@DisplayForm.ReportTemplateName" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label form-label-sm">PDF Password Scheme</label>
                        <select name="PdfPasswordScheme" class="form-select form-select-sm">
                            <option value="" selected="@(string.IsNullOrEmpty(DisplayForm.PdfPasswordScheme))">None</option>
                            <option value="DOB" selected="@(DisplayForm.PdfPasswordScheme == "DOB")">DOB (Date of Birth)</option>
                            <option value="CARD4" selected="@(DisplayForm.PdfPasswordScheme == "CARD4")">CARD4 (Last 4 digits)</option>
                        </select>
                    </div>

                    <div class="col-12 mt-2"><h6 class="mb-1 text-muted">Email / Branding</h6></div>
                    <div class="col-md-6">
                        <label class="form-label form-label-sm">Email From Address</label>
                        <input name="EmailFromAddress" class="form-control form-control-sm"
                               value="@DisplayForm.EmailFromAddress" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label form-label-sm">Bank Website URL</label>
                        <input name="BankWebsiteUrl" class="form-control form-control-sm"
                               value="@DisplayForm.BankWebsiteUrl" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label form-label-sm">Facebook URL</label>
                        <input name="FacebookUrl" class="form-control form-control-sm"
                               value="@DisplayForm.FacebookUrl" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label form-label-sm">LinkedIn URL</label>
                        <input name="LinkedInUrl" class="form-control form-control-sm"
                               value="@DisplayForm.LinkedInUrl" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label form-label-sm">YouTube URL</label>
                        <input name="YouTubeUrl" class="form-control form-control-sm"
                               value="@DisplayForm.YouTubeUrl" />
                    </div>

                    <div class="col-12 mt-2"><h6 class="mb-1 text-muted">Pagination &amp; Timing</h6></div>
                    <div class="col-md-4">
                        <label class="form-label form-label-sm">Max Trans / Page</label>
                        <input type="number" name="MaxTransactionsPerPage" class="form-control form-control-sm"
                               value="@DisplayForm.MaxTransactionsPerPage" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label form-label-sm">Max Trans Last Page</label>
                        <input type="number" name="MaxTransactionsLastPage" class="form-control form-control-sm"
                               value="@DisplayForm.MaxTransactionsLastPage" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label form-label-sm">Email Wait (ms)</label>
                        <input type="number" name="EmailWaitPeriodMs" class="form-control form-control-sm"
                               value="@DisplayForm.EmailWaitPeriodMs" />
                    </div>

                    <div class="col-12 mt-2"><h6 class="mb-1 text-muted">Display</h6></div>
                    <div class="col-12">
                        <label class="form-label form-label-sm">Display Name</label>
                        <input name="DisplayName" class="form-control form-control-sm"
                               placeholder="29) UBA United Bank for Africa >> Credit Emails 1/m"
                               value="@DisplayForm.DisplayName" />
                    </div>
                </div>

                <div class="d-flex gap-2 justify-content-end mt-3">
                    <a href="/bank-config" class="btn btn-secondary btn-sm">Cancel</a>
                    <button type="submit" class="btn btn-primary btn-sm">Save</button>
                </div>
            </form>
        </div>
    </div>
}

@* ── Delete confirmation ──────────────────────────────────────────────── *@
@if (Mode == "delete" && DeleteTarget != null)
{
    <div class="card mb-4 border-danger shadow-sm">
        <div class="card-header text-danger">Confirm Delete</div>
        <div class="card-body">
            <p>Delete <strong>@DeleteTarget.BankName — @DeleteTarget.FormatterKey</strong> (ID @DeleteTarget.Id)?</p>
            <p class="text-muted small mb-0">This action cannot be undone.</p>
        </div>
        <div class="card-footer d-flex gap-2 justify-content-end">
            <a href="/bank-config" class="btn btn-secondary btn-sm">Cancel</a>
            <form method="post" @formname="delete-form" class="d-inline">
                <AntiforgeryToken />
                <input type="hidden" name="ConfigId" value="@DeleteTarget.Id" />
                <button type="submit" class="btn btn-danger btn-sm">Delete</button>
            </form>
        </div>
    </div>
}

@* ── Filter bar ───────────────────────────────────────────────────────── *@
<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <input name="q" class="form-control form-control-sm"
               placeholder="Filter by bank, key, branch…" value="@Q" />
    </div>
    <div class="col-md-2">
        <select name="type" class="form-select form-select-sm">
            <option value="">All types</option>
            @foreach (var v in Enum.GetValues<StatementOutputType>())
            {
                <option value="@((int)v)" selected="@(Type == ((int)v).ToString())">@v</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <select name="active" class="form-select form-select-sm">
            <option value="">Active + Inactive</option>
            <option value="1" selected="@(Active == "1")">Active only</option>
            <option value="0" selected="@(Active == "0")">Inactive only</option>
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-outline-secondary btn-sm w-100">↺ Filter</button>
    </div>
    <div class="col-md-2 text-muted text-end align-self-center">
        <small>@Filtered.Count() of @All.Count rows</small>
    </div>
</form>

@* ── Configuration table ──────────────────────────────────────────────── *@
<div class="table-responsive" style="max-height:520px;overflow-y:auto">
    <table class="table table-sm table-bordered table-hover align-middle">
        <thead class="table-light sticky-top">
            <tr>
                <th>ID</th>
                <th>Branch</th>
                <th>Bank</th>
                <th>Card Product</th>
                <th>Formatter Key</th>
                <th>Type</th>
                <th>Suffix</th>
                <th>Day</th>
                <th>Active</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var cfg in Filtered)
            {
                <tr class="@(cfg.IsActive ? "" : "text-muted")">
                    <td><small>@cfg.Id</small></td>
                    <td><small>@cfg.BranchCode</small></td>
                    <td>
                        <strong>@cfg.BankName</strong>
                        <br /><small class="text-muted">@cfg.BankFullName</small>
                    </td>
                    <td><small>@cfg.CardProduct</small></td>
                    <td><span class="badge bg-secondary">@cfg.FormatterKey</span></td>
                    <td><small>@((StatementOutputType)cfg.OutputType)</small></td>
                    <td><small>@cfg.StatementTypeSuffix</small></td>
                    <td><small>@cfg.ScheduledDay</small></td>
                    <td>
                        @if (cfg.IsActive)
                        {
                            <span class="badge bg-success">Yes</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">No</span>
                        }
                    </td>
                    <td>
                        <a href="/bank-config?mode=edit&id=@cfg.Id"
                           class="btn btn-outline-primary btn-sm py-0 px-2 me-1" title="Edit">✎</a>
                        <a href="/bank-config?mode=delete&id=@cfg.Id"
                           class="btn btn-outline-danger btn-sm py-0 px-2" title="Delete">✕</a>
                    </td>
                </tr>
            }
            @if (!Filtered.Any())
            {
                <tr>
                    <td colspan="10" class="text-center text-muted py-4">No configurations found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    // ── Query parameters ───────────────────────────────────────────────────────
    [Parameter][SupplyParameterFromQuery] public string Mode   { get; set; } = string.Empty;
    [Parameter][SupplyParameterFromQuery] public int    Id     { get; set; }
    [Parameter][SupplyParameterFromQuery] public string Q      { get; set; } = string.Empty;
    [Parameter][SupplyParameterFromQuery] public string Type   { get; set; } = string.Empty;
    [Parameter][SupplyParameterFromQuery] public string Active { get; set; } = string.Empty;

    // ── Form models ────────────────────────────────────────────────────────────
    [SupplyParameterFromForm(FormName = "config-form")]
    private BankConfigFormModel ConfigForm { get; set; }

    [SupplyParameterFromForm(FormName = "delete-form")]
    private DeleteFormModel DeleteForm { get; set; }

    // ── Data ───────────────────────────────────────────────────────────────────
    private List<BankProductConfigDto> All          { get; } = new();
    private BankProductConfigDto       DeleteTarget { get; set; }
    private BankConfigFormModel        DisplayForm  { get; set; } = new();
    private string                     FormError    { get; set; }

    private IEnumerable<BankProductConfigDto> Filtered => All.Where(c =>
    {
        if (!string.IsNullOrWhiteSpace(Q) &&
            !c.BankName.Contains(Q, StringComparison.OrdinalIgnoreCase) &&
            !c.BankFullName.Contains(Q, StringComparison.OrdinalIgnoreCase) &&
            !c.FormatterKey.Contains(Q, StringComparison.OrdinalIgnoreCase) &&
            !c.BranchCode.ToString().Contains(Q))
            return false;

        if (!string.IsNullOrWhiteSpace(Type) && c.OutputType != int.Parse(Type))
            return false;

        if (!string.IsNullOrWhiteSpace(Active) && (c.IsActive ? 1 : 0) != int.Parse(Active))
            return false;

        return true;
    });

    private static readonly ProcessingMode[] NonStandardModes = Enum
        .GetValues<ProcessingMode>()
        .Where(m => m != ProcessingMode.Standard)
        .ToArray();

    protected override async Task OnInitializedAsync()
    {
        // ── Handle config form POST ──
        if (ConfigForm != null)
        {
            await SaveConfigAsync();
            if (string.IsNullOrEmpty(FormError))
            {
                Nav.NavigateTo("/bank-config", replace: true);
                return;
            }
            // On error: fall through to load data for display
            DisplayForm = ConfigForm;
        }

        // ── Handle delete form POST ──
        if (DeleteForm != null)
        {
            try
            {
                await BankConfigApi.DeleteAsync(DeleteForm.ConfigId);
            }
            catch { /* swallow — user sees the table reload */ }
            Nav.NavigateTo("/bank-config", replace: true);
            return;
        }

        // ── Load all configs for the table ──
        try
        {
            var rows = await BankConfigApi.GetAllAsync();
            All.AddRange(rows);
        }
        catch { /* table stays empty */ }

        // ── Pre-populate edit form on GET ──
        if (Mode == "edit" && Id > 0 && ConfigForm == null)
        {
            var cfg = All.FirstOrDefault(c => c.Id == Id);
            if (cfg != null)
            {
                DisplayForm = new BankConfigFormModel
                {
                    BranchCode                   = cfg.BranchCode,
                    BankName                     = cfg.BankName                     ?? string.Empty,
                    BankFullName                 = cfg.BankFullName                 ?? string.Empty,
                    CardProduct                  = cfg.CardProduct                  ?? string.Empty,
                    OutputType                   = cfg.OutputType,
                    FormatterKey                 = cfg.FormatterKey                 ?? string.Empty,
                    ProcessingModes              = cfg.ProcessingModes,
                    CardType                     = cfg.CardType,
                    StatementType                = cfg.StatementType,
                    StatementTypeSuffix          = cfg.StatementTypeSuffix          ?? "CR",
                    RewardContractCondition      = cfg.RewardContractCondition      ?? string.Empty,
                    InstallmentContractCondition = cfg.InstallmentContractCondition ?? string.Empty,
                    AppendMode                   = cfg.AppendMode,
                    UseCorporateAccountNumber    = cfg.UseCorporateAccountNumber,
                    ReportTemplateName           = cfg.ReportTemplateName           ?? string.Empty,
                    PdfPasswordScheme            = cfg.PdfPasswordScheme            ?? string.Empty,
                    EmailFromAddress             = cfg.EmailFromAddress             ?? "cardservices@emp-group.com",
                    BankWebsiteUrl               = cfg.BankWebsiteUrl               ?? string.Empty,
                    FacebookUrl                  = cfg.FacebookUrl                  ?? string.Empty,
                    LinkedInUrl                  = cfg.LinkedInUrl                  ?? string.Empty,
                    YouTubeUrl                   = cfg.YouTubeUrl                   ?? string.Empty,
                    MaxTransactionsPerPage       = cfg.MaxTransactionsPerPage,
                    MaxTransactionsLastPage      = cfg.MaxTransactionsLastPage,
                    EmailWaitPeriodMs            = cfg.EmailWaitPeriodMs,
                    FieldSeparator               = cfg.FieldSeparator               ?? ",",
                    ScheduledDay                 = cfg.ScheduledDay,
                    DisplayName                  = cfg.DisplayName                  ?? string.Empty,
                    SortOrder                    = cfg.SortOrder,
                    IsActive                     = cfg.IsActive,
                };
            }
        }

        // ── Load delete target on GET ──
        if (Mode == "delete" && Id > 0)
            DeleteTarget = All.FirstOrDefault(c => c.Id == Id);
    }

    private async Task SaveConfigAsync()
    {
        if (string.IsNullOrWhiteSpace(ConfigForm.BankName))      { FormError = "Bank Code is required.";         return; }
        if (string.IsNullOrWhiteSpace(ConfigForm.FormatterKey))  { FormError = "Formatter Key is required.";     return; }
        if (ConfigForm.ScheduledDay < 1 || ConfigForm.ScheduledDay > 31) { FormError = "Scheduled Day must be 1–31."; return; }

        var req = new SaveBankProductConfigRequest
        {
            BranchCode                   = ConfigForm.BranchCode,
            BankName                     = ConfigForm.BankName,
            BankFullName                 = ConfigForm.BankFullName,
            CardProduct                  = ConfigForm.CardProduct,
            OutputType                   = ConfigForm.OutputType,
            FormatterKey                 = ConfigForm.FormatterKey,
            ProcessingModes              = (ConfigForm.SelectedModes ?? Array.Empty<long>()).Aggregate(0L, (acc, m) => acc | m),
            CardType                     = ConfigForm.CardType,
            StatementType                = ConfigForm.StatementType,
            StatementTypeSuffix          = ConfigForm.StatementTypeSuffix,
            RewardContractCondition      = ConfigForm.RewardContractCondition,
            InstallmentContractCondition = ConfigForm.InstallmentContractCondition,
            AppendMode                   = ConfigForm.AppendMode,
            UseCorporateAccountNumber    = ConfigForm.UseCorporateAccountNumber,
            ReportTemplateName           = ConfigForm.ReportTemplateName,
            PdfPasswordScheme            = ConfigForm.PdfPasswordScheme,
            EmailFromAddress             = ConfigForm.EmailFromAddress,
            BankWebsiteUrl               = ConfigForm.BankWebsiteUrl,
            FacebookUrl                  = ConfigForm.FacebookUrl,
            LinkedInUrl                  = ConfigForm.LinkedInUrl,
            YouTubeUrl                   = ConfigForm.YouTubeUrl,
            MaxTransactionsPerPage       = ConfigForm.MaxTransactionsPerPage,
            MaxTransactionsLastPage      = ConfigForm.MaxTransactionsLastPage,
            EmailWaitPeriodMs            = ConfigForm.EmailWaitPeriodMs,
            FieldSeparator               = ConfigForm.FieldSeparator,
            ScheduledDay                 = ConfigForm.ScheduledDay,
            DisplayName                  = ConfigForm.DisplayName,
            SortOrder                    = ConfigForm.SortOrder,
            IsActive                     = ConfigForm.IsActive,
        };

        try
        {
            if (ConfigForm.EditingId == 0)
                await BankConfigApi.CreateAsync(req);
            else
                await BankConfigApi.UpdateAsync(ConfigForm.EditingId, req);
        }
        catch (Exception ex)
        {
            FormError = ex.Message;
        }
    }

    // ── Form models ────────────────────────────────────────────────────────────

    private sealed class BankConfigFormModel
    {
        public int    EditingId                    { get; set; }
        public int    BranchCode                   { get; set; }
        public string BankName                     { get; set; } = string.Empty;
        public string BankFullName                 { get; set; } = string.Empty;
        public string CardProduct                  { get; set; } = string.Empty;
        public int    OutputType                   { get; set; }
        public string FormatterKey                 { get; set; } = string.Empty;
        public long   ProcessingModes              { get; set; }
        public long[] SelectedModes                { get; set; } = Array.Empty<long>();
        public int    CardType                     { get; set; }
        public int    StatementType                { get; set; }
        public string StatementTypeSuffix          { get; set; } = "CR";
        public string RewardContractCondition      { get; set; } = string.Empty;
        public string InstallmentContractCondition { get; set; } = string.Empty;
        public bool   AppendMode                   { get; set; }
        public bool   UseCorporateAccountNumber    { get; set; }
        public string ReportTemplateName           { get; set; } = string.Empty;
        public string PdfPasswordScheme            { get; set; } = string.Empty;
        public string EmailFromAddress             { get; set; } = "cardservices@emp-group.com";
        public string BankWebsiteUrl               { get; set; } = string.Empty;
        public string FacebookUrl                  { get; set; } = string.Empty;
        public string LinkedInUrl                  { get; set; } = string.Empty;
        public string YouTubeUrl                   { get; set; } = string.Empty;
        public int    MaxTransactionsPerPage       { get; set; } = 20;
        public int    MaxTransactionsLastPage      { get; set; } = 27;
        public int    EmailWaitPeriodMs            { get; set; } = 7000;
        public string FieldSeparator               { get; set; } = ",";
        public int    ScheduledDay                 { get; set; } = 1;
        public string DisplayName                  { get; set; } = string.Empty;
        public int    SortOrder                    { get; set; }
        public bool   IsActive                     { get; set; } = true;
    }

    private sealed class DeleteFormModel
    {
        public int ConfigId { get; set; }
    }
}
