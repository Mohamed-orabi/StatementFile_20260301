@page "/bank-config"
@rendermode InteractiveServer
@inject StatementApiClient Api
@inject AppState AppState
@inject NavigationManager Nav
@using StatementFile.Application.DTOs
@using StatementFile.Domain.Enums
@using StatementFile.Presentation.Services

<PageTitle>Bank Configuration — StatementFile</PageTitle>

@if (!AppState.IsLoggedIn)
{
    Nav.NavigateTo("/login", replace: true);
    return;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Bank / Product Configuration</h4>
    <div class="d-flex gap-2">
        <button class="btn btn-success btn-sm" @onclick="OpenCreateForm">
            + New Configuration
        </button>
        <a href="/" class="btn btn-outline-secondary btn-sm">← Back to Generation</a>
    </div>
</div>

@if (AlertMessage != null)
{
    <div class="alert @(AlertIsError ? "alert-danger" : "alert-success") alert-dismissible py-2">
        @AlertMessage
        <button type="button" class="btn-close" @onclick="() => AlertMessage = null"></button>
    </div>
}

<!-- Search & filter bar -->
<div class="row g-2 mb-3">
    <div class="col-md-4">
        <input class="form-control form-control-sm"
               placeholder="Filter by bank, key, branch…"
               @bind="SearchText"
               @bind:event="oninput" />
    </div>
    <div class="col-md-2">
        <select class="form-select form-select-sm" @bind="FilterOutputType">
            <option value="">All types</option>
            @foreach (var v in Enum.GetValues<StatementOutputType>())
            {
                <option value="@((int)v)">@v</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <select class="form-select form-select-sm" @bind="FilterActive">
            <option value="">Active + Inactive</option>
            <option value="1">Active only</option>
            <option value="0">Inactive only</option>
        </select>
    </div>
    <div class="col-md-2">
        <button class="btn btn-outline-secondary btn-sm w-100" @onclick="LoadAll">↺ Reload</button>
    </div>
    <div class="col-md-2 text-muted text-end">
        <small>@Filtered.Count() of @All.Count rows</small>
    </div>
</div>

<!-- Configuration table -->
<div class="table-responsive" style="max-height:520px;overflow-y:auto">
    <table class="table table-sm table-bordered table-hover align-middle">
        <thead class="table-light sticky-top">
            <tr>
                <th>ID</th>
                <th>Branch</th>
                <th>Bank</th>
                <th>Card Product</th>
                <th>Formatter Key</th>
                <th>Type</th>
                <th>Suffix</th>
                <th>Day</th>
                <th>Active</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var cfg in Filtered)
            {
                <tr class="@(cfg.IsActive ? "" : "text-muted")">
                    <td><small>@cfg.Id</small></td>
                    <td><small>@cfg.BranchCode</small></td>
                    <td>
                        <strong>@cfg.BankName</strong>
                        <br /><small class="text-muted">@cfg.BankFullName</small>
                    </td>
                    <td><small>@cfg.CardProduct</small></td>
                    <td>
                        <span class="badge bg-secondary">@cfg.FormatterKey</span>
                    </td>
                    <td><small>@((StatementOutputType)cfg.OutputType)</small></td>
                    <td><small>@cfg.StatementTypeSuffix</small></td>
                    <td><small>@cfg.ScheduledDay</small></td>
                    <td>
                        @if (cfg.IsActive)
                        {
                            <span class="badge bg-success">Yes</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">No</span>
                        }
                    </td>
                    <td>
                        <button class="btn btn-outline-primary btn-sm py-0 px-2 me-1"
                                title="Edit"
                                @onclick="() => OpenEditForm(cfg)">
                            ✎
                        </button>
                        <button class="btn btn-outline-danger btn-sm py-0 px-2"
                                title="Delete"
                                @onclick="() => ConfirmDelete(cfg)">
                            ✕
                        </button>
                    </td>
                </tr>
            }
            @if (!Filtered.Any())
            {
                <tr>
                    <td colspan="10" class="text-center text-muted py-4">No configurations found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- ── Create/Edit modal ──────────────────────────────────────────────────── -->
@if (ShowForm)
{
    <div class="modal-backdrop-custom" @onclick="CloseForm"></div>
    <div class="card position-fixed shadow-lg" style="top:60px;left:50%;transform:translateX(-50%);width:min(98vw,780px);z-index:1050;max-height:90vh;overflow-y:auto">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>@(Form.Id == 0 ? "New Configuration" : $"Edit Configuration #{Form.Id}")</span>
            <button class="btn-close" @onclick="CloseForm"></button>
        </div>
        <div class="card-body">
            <div class="row g-2">

                <!-- ── Identity ─────────────────────────────────────────────── -->
                <div class="col-12"><h6 class="mb-1 text-muted">Identity</h6></div>

                <div class="col-md-2">
                    <label class="form-label form-label-sm">Branch Code</label>
                    <input type="number" class="form-control form-control-sm" @bind="Form.BranchCode" />
                </div>
                <div class="col-md-2">
                    <label class="form-label form-label-sm">Bank Code</label>
                    <input class="form-control form-control-sm" @bind="Form.BankName" placeholder="UBA" />
                </div>
                <div class="col-md-4">
                    <label class="form-label form-label-sm">Bank Full Name</label>
                    <input class="form-control form-control-sm" @bind="Form.BankFullName" placeholder="United Bank for Africa" />
                </div>
                <div class="col-md-4">
                    <label class="form-label form-label-sm">Card Product</label>
                    <input class="form-control form-control-sm" @bind="Form.CardProduct" placeholder="UBACR" />
                </div>

                <!-- ── Output ─────────────────────────────────────────────── -->
                <div class="col-12 mt-2"><h6 class="mb-1 text-muted">Output</h6></div>

                <div class="col-md-4">
                    <label class="form-label form-label-sm">Output Type</label>
                    <select class="form-select form-select-sm" @bind="Form.OutputType">
                        @foreach (var v in Enum.GetValues<StatementOutputType>())
                        {
                            <option value="@((int)v)">@v</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label form-label-sm">Formatter Key</label>
                    <input class="form-control form-control-sm" @bind="Form.FormatterKey" placeholder="HTML_UBA" />
                </div>
                <div class="col-md-2">
                    <label class="form-label form-label-sm">Stmt Suffix</label>
                    <input class="form-control form-control-sm" @bind="Form.StatementTypeSuffix" placeholder="CR" />
                </div>
                <div class="col-md-2">
                    <label class="form-label form-label-sm">Sched. Day</label>
                    <input type="number" min="1" max="31" class="form-control form-control-sm" @bind="Form.ScheduledDay" />
                </div>

                <!-- ── Card classification ──────────────────────────────── -->
                <div class="col-md-3">
                    <label class="form-label form-label-sm">Card Type</label>
                    <select class="form-select form-select-sm" @bind="Form.CardType">
                        @foreach (var v in Enum.GetValues<CardType>())
                        {
                            <option value="@((int)v)">@v</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label form-label-sm">Statement Type</label>
                    <select class="form-select form-select-sm" @bind="Form.StatementType">
                        @foreach (var v in Enum.GetValues<StatementType>())
                        {
                            <option value="@((int)v)">@v</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label form-label-sm">Field Separator</label>
                    <input class="form-control form-control-sm" @bind="Form.FieldSeparator" placeholder="," />
                </div>
                <div class="col-md-3">
                    <label class="form-label form-label-sm">Sort Order</label>
                    <input type="number" class="form-control form-control-sm" @bind="Form.SortOrder" />
                </div>

                <!-- ── Flags ─────────────────────────────────────────────── -->
                <div class="col-12 mt-2"><h6 class="mb-1 text-muted">Flags</h6></div>
                <div class="col-md-3">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="fAppend" @bind="Form.AppendMode" />
                        <label class="form-check-label" for="fAppend">Append Mode</label>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="fCorp" @bind="Form.UseCorporateAccountNumber" />
                        <label class="form-check-label" for="fCorp">Corporate Account No.</label>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="fActive" @bind="Form.IsActive" />
                        <label class="form-check-label" for="fActive">Active</label>
                    </div>
                </div>

                <!-- ── Processing Modes ──────────────────────────────────── -->
                <div class="col-12 mt-2"><h6 class="mb-1 text-muted">Processing Modes</h6></div>
                <div class="col-12">
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var mode in NonStandardModes)
                        {
                            <div class="form-check form-check-inline mb-0">
                                <input class="form-check-input" type="checkbox"
                                       id="pm_@mode"
                                       checked="@HasMode(mode)"
                                       @onchange="e => ToggleMode(mode, (bool)e.Value)" />
                                <label class="form-check-label" for="pm_@mode">
                                    <small>@mode</small>
                                </label>
                            </div>
                        }
                    </div>
                </div>

                <!-- ── Oracle conditions ─────────────────────────────────── -->
                <div class="col-12 mt-2"><h6 class="mb-1 text-muted">Oracle Conditions</h6></div>
                <div class="col-12">
                    <label class="form-label form-label-sm">Reward Contract Condition</label>
                    <input class="form-control form-control-sm"
                           @bind="Form.RewardContractCondition"
                           placeholder="'New Reward Contract'" />
                </div>
                <div class="col-12">
                    <label class="form-label form-label-sm">Installment Contract Condition</label>
                    <input class="form-control form-control-sm"
                           @bind="Form.InstallmentContractCondition"
                           placeholder="'Purchase Installment With Interest Rate'" />
                </div>

                <!-- ── PDF ────────────────────────────────────────────────── -->
                <div class="col-12 mt-2"><h6 class="mb-1 text-muted">PDF (optional)</h6></div>
                <div class="col-md-6">
                    <label class="form-label form-label-sm">Report Template Name</label>
                    <input class="form-control form-control-sm" @bind="Form.ReportTemplateName" placeholder="CreditStatement.rpt" />
                </div>
                <div class="col-md-6">
                    <label class="form-label form-label-sm">PDF Password Scheme</label>
                    <select class="form-select form-select-sm" @bind="Form.PdfPasswordScheme">
                        <option value="">None</option>
                        <option value="DOB">DOB (Date of Birth)</option>
                        <option value="CARD4">CARD4 (Last 4 digits)</option>
                    </select>
                </div>

                <!-- ── Email / Branding ──────────────────────────────────── -->
                <div class="col-12 mt-2"><h6 class="mb-1 text-muted">Email / Branding</h6></div>
                <div class="col-md-6">
                    <label class="form-label form-label-sm">Email From Address</label>
                    <input class="form-control form-control-sm" @bind="Form.EmailFromAddress" />
                </div>
                <div class="col-md-6">
                    <label class="form-label form-label-sm">Bank Website URL</label>
                    <input class="form-control form-control-sm" @bind="Form.BankWebsiteUrl" />
                </div>
                <div class="col-md-4">
                    <label class="form-label form-label-sm">Facebook URL</label>
                    <input class="form-control form-control-sm" @bind="Form.FacebookUrl" />
                </div>
                <div class="col-md-4">
                    <label class="form-label form-label-sm">LinkedIn URL</label>
                    <input class="form-control form-control-sm" @bind="Form.LinkedInUrl" />
                </div>
                <div class="col-md-4">
                    <label class="form-label form-label-sm">YouTube URL</label>
                    <input class="form-control form-control-sm" @bind="Form.YouTubeUrl" />
                </div>

                <!-- ── Pagination / Timing ───────────────────────────────── -->
                <div class="col-12 mt-2"><h6 class="mb-1 text-muted">Pagination &amp; Timing</h6></div>
                <div class="col-md-4">
                    <label class="form-label form-label-sm">Max Trans / Page</label>
                    <input type="number" class="form-control form-control-sm" @bind="Form.MaxTransactionsPerPage" />
                </div>
                <div class="col-md-4">
                    <label class="form-label form-label-sm">Max Trans Last Page</label>
                    <input type="number" class="form-control form-control-sm" @bind="Form.MaxTransactionsLastPage" />
                </div>
                <div class="col-md-4">
                    <label class="form-label form-label-sm">Email Wait (ms)</label>
                    <input type="number" class="form-control form-control-sm" @bind="Form.EmailWaitPeriodMs" />
                </div>

                <!-- ── Display ───────────────────────────────────────────── -->
                <div class="col-12 mt-2"><h6 class="mb-1 text-muted">Display</h6></div>
                <div class="col-12">
                    <label class="form-label form-label-sm">Display Name (shown in UI)</label>
                    <input class="form-control form-control-sm" @bind="Form.DisplayName"
                           placeholder="29) UBA United Bank for Africa Plc Nigeria >> Credit Emails 1/m" />
                </div>

            </div>

            @if (FormError != null)
            {
                <div class="alert alert-danger py-1 mt-2">@FormError</div>
            }
        </div>
        <div class="card-footer d-flex gap-2 justify-content-end">
            <button class="btn btn-secondary btn-sm" @onclick="CloseForm">Cancel</button>
            <button class="btn btn-primary btn-sm" @onclick="SaveForm" disabled="@FormBusy">
                @(FormBusy ? "Saving…" : "Save")
            </button>
        </div>
    </div>
}

<!-- ── Delete confirmation dialog ──────────────────────────────────────────── -->
@if (DeleteTarget != null)
{
    <div class="modal-backdrop-custom" @onclick="() => DeleteTarget = null"></div>
    <div class="card position-fixed shadow-lg" style="top:200px;left:50%;transform:translateX(-50%);width:400px;z-index:1060">
        <div class="card-header text-danger">Confirm Delete</div>
        <div class="card-body">
            <p>Delete <strong>@DeleteTarget.BankName — @DeleteTarget.FormatterKey</strong> (ID @DeleteTarget.Id)?</p>
            <p class="text-muted small">This action cannot be undone.</p>
        </div>
        <div class="card-footer d-flex gap-2 justify-content-end">
            <button class="btn btn-secondary btn-sm" @onclick="() => DeleteTarget = null">Cancel</button>
            <button class="btn btn-danger btn-sm" @onclick="ExecuteDelete">Delete</button>
        </div>
    </div>
}

<style>
    .modal-backdrop-custom {
        position: fixed; inset: 0;
        background: rgba(0,0,0,.35);
        z-index: 1040;
    }
</style>

@code {
    // ── Data ──────────────────────────────────────────────────────────────────
    private List<BankConfigDto> All             { get; } = new();
    private string              SearchText      { get; set; } = string.Empty;
    private string              FilterOutputType{ get; set; } = string.Empty;
    private string              FilterActive    { get; set; } = string.Empty;
    private string              AlertMessage    { get; set; }
    private bool                AlertIsError    { get; set; }

    private IEnumerable<BankConfigDto> Filtered =>
        All.Where(c =>
        {
            if (!string.IsNullOrWhiteSpace(SearchText) &&
                !c.BankName.Contains(SearchText, StringComparison.OrdinalIgnoreCase) &&
                !c.BankFullName.Contains(SearchText, StringComparison.OrdinalIgnoreCase) &&
                !c.FormatterKey.Contains(SearchText, StringComparison.OrdinalIgnoreCase) &&
                !c.BranchCode.ToString().Contains(SearchText))
                return false;

            if (!string.IsNullOrWhiteSpace(FilterOutputType) &&
                c.OutputType != int.Parse(FilterOutputType))
                return false;

            if (!string.IsNullOrWhiteSpace(FilterActive) &&
                (c.IsActive ? 1 : 0) != int.Parse(FilterActive))
                return false;

            return true;
        });

    private static readonly ProcessingMode[] NonStandardModes = Enum
        .GetValues<ProcessingMode>()
        .Where(m => m != ProcessingMode.Standard)
        .ToArray();

    protected override async Task OnInitializedAsync() => await LoadAll();

    private async Task LoadAll()
    {
        All.Clear();
        try
        {
            var list = await Api.GetAllBankConfigsAsync();
            All.AddRange(list);
        }
        catch (Exception ex)
        {
            ShowAlert($"Failed to load configurations: {ex.Message}", error: true);
        }
    }

    // ── Processing mode helpers ───────────────────────────────────────────────
    private bool HasMode(ProcessingMode m) => ((ProcessingMode)Form.ProcessingModes).HasFlag(m);

    private void ToggleMode(ProcessingMode m, bool on)
    {
        var current = (ProcessingMode)Form.ProcessingModes;
        Form.ProcessingModes = (long)(on ? current | m : current & ~m);
    }

    // ── Create / Edit form ────────────────────────────────────────────────────
    private bool       ShowForm  { get; set; }
    private bool       FormBusy  { get; set; }
    private BankConfigDto Form   { get; set; } = new();
    private string     FormError { get; set; }

    private void OpenCreateForm()
    {
        Form      = new BankConfigDto
        {
            StatementTypeSuffix          = "CR",
            RewardContractCondition      = "'New Reward Contract'",
            EmailFromAddress             = "cardservices@emp-group.com",
            MaxTransactionsPerPage       = 20,
            MaxTransactionsLastPage      = 27,
            EmailWaitPeriodMs            = 7000,
            FieldSeparator               = ",",
            ScheduledDay                 = 1,
            IsActive                     = true,
        };
        FormError = null;
        ShowForm  = true;
    }

    private void OpenEditForm(BankConfigDto cfg)
    {
        // Shallow copy so edits don't affect the list until saved
        Form = new BankConfigDto
        {
            Id                           = cfg.Id,
            BranchCode                   = cfg.BranchCode,
            BankName                     = cfg.BankName,
            BankFullName                 = cfg.BankFullName,
            CardProduct                  = cfg.CardProduct,
            OutputType                   = cfg.OutputType,
            FormatterKey                 = cfg.FormatterKey,
            ProcessingModes              = cfg.ProcessingModes,
            CardType                     = cfg.CardType,
            StatementType                = cfg.StatementType,
            StatementTypeSuffix          = cfg.StatementTypeSuffix,
            RewardContractCondition      = cfg.RewardContractCondition ?? string.Empty,
            InstallmentContractCondition = cfg.InstallmentContractCondition ?? string.Empty,
            AppendMode                   = cfg.AppendMode,
            UseCorporateAccountNumber    = cfg.UseCorporateAccountNumber,
            ReportTemplateName           = cfg.ReportTemplateName  ?? string.Empty,
            PdfPasswordScheme            = cfg.PdfPasswordScheme   ?? string.Empty,
            EmailFromAddress             = cfg.EmailFromAddress     ?? "cardservices@emp-group.com",
            BankWebsiteUrl               = cfg.BankWebsiteUrl      ?? string.Empty,
            FacebookUrl                  = cfg.FacebookUrl          ?? string.Empty,
            LinkedInUrl                  = cfg.LinkedInUrl          ?? string.Empty,
            YouTubeUrl                   = cfg.YouTubeUrl           ?? string.Empty,
            MaxTransactionsPerPage       = cfg.MaxTransactionsPerPage,
            MaxTransactionsLastPage      = cfg.MaxTransactionsLastPage,
            EmailWaitPeriodMs            = cfg.EmailWaitPeriodMs,
            FieldSeparator               = cfg.FieldSeparator,
            ScheduledDay                 = cfg.ScheduledDay,
            DisplayName                  = cfg.DisplayName ?? string.Empty,
            SortOrder                    = cfg.SortOrder,
            IsActive                     = cfg.IsActive,
        };
        FormError = null;
        ShowForm  = true;
    }

    private void CloseForm()
    {
        ShowForm  = false;
        FormError = null;
    }

    private async Task SaveForm()
    {
        FormError = null;

        if (string.IsNullOrWhiteSpace(Form.BankName))       { FormError = "Bank Code is required."; return; }
        if (string.IsNullOrWhiteSpace(Form.FormatterKey))   { FormError = "Formatter Key is required."; return; }
        if (Form.ScheduledDay < 1 || Form.ScheduledDay > 31){ FormError = "Scheduled Day must be 1–31."; return; }

        FormBusy = true;
        try
        {
            if (Form.Id == 0)
            {
                var (newId, error) = await Api.CreateBankConfigAsync(Form);
                if (error != null) { FormError = error; return; }
                ShowAlert($"Configuration #{newId} created.");
            }
            else
            {
                var error = await Api.UpdateBankConfigAsync(Form.Id, Form);
                if (error != null) { FormError = error; return; }
                ShowAlert($"Configuration #{Form.Id} updated.");
            }

            CloseForm();
            await LoadAll();
        }
        catch (Exception ex)
        {
            FormError = ex.Message;
        }
        finally
        {
            FormBusy = false;
        }
    }

    // ── Delete ────────────────────────────────────────────────────────────────
    private BankConfigDto DeleteTarget { get; set; }

    private void ConfirmDelete(BankConfigDto cfg) => DeleteTarget = cfg;

    private async Task ExecuteDelete()
    {
        if (DeleteTarget == null) return;
        try
        {
            var error = await Api.DeleteBankConfigAsync(DeleteTarget.Id);
            if (error != null)
                ShowAlert($"Delete failed: {error}", error: true);
            else
                ShowAlert($"Configuration #{DeleteTarget.Id} deleted.");
        }
        catch (Exception ex)
        {
            ShowAlert($"Delete failed: {ex.Message}", error: true);
        }
        finally
        {
            DeleteTarget = null;
            await LoadAll();
        }
    }

    // ── Helpers ───────────────────────────────────────────────────────────────
    private void ShowAlert(string msg, bool error = false)
    {
        AlertMessage = msg;
        AlertIsError = error;
    }
}
