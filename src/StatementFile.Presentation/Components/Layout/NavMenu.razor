@inject IHttpContextAccessor HttpContextAccessor

@{
    var user      = HttpContextAccessor.HttpContext?.User;
    bool loggedIn = user?.Identity?.IsAuthenticated == true;
    string userName = loggedIn ? (user.Identity.Name ?? string.Empty) : string.Empty;
}

@if (loggedIn)
{
    <NavLink class="nav-link text-white-50 d-block mb-1 ps-1"
             href="/"
             Match="NavLinkMatch.All"
             ActiveClass="text-white fw-semibold">
        Statement Generation
    </NavLink>

    <NavLink class="nav-link text-white-50 d-block mb-1 ps-1"
             href="/merchant"
             ActiveClass="text-white fw-semibold">
        Merchant Statement
    </NavLink>

    <NavLink class="nav-link text-white-50 d-block mb-1 ps-1"
             href="/bank-config"
             ActiveClass="text-white fw-semibold">
        Bank Configuration
    </NavLink>

    <hr class="border-secondary mt-3 mb-2" />

    <small class="text-secondary d-block mb-2">@userName</small>

    <form method="post" action="/logout">
        <AntiforgeryToken />
        <button type="submit" class="btn btn-outline-light btn-sm w-100">Logout</button>
    </form>
}
else
{
    <NavLink class="nav-link text-white-50 d-block mb-1 ps-1"
             href="/login"
             ActiveClass="text-white fw-semibold">
        Login
    </NavLink>
}
