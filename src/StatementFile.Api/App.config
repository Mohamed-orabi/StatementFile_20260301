<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <appSettings>

    <!-- Oracle connection -->
    <add key="ServerName"  value="YOUR_ORACLE_TNS_NAME" />
    <add key="MainSchema"  value="YOUR_SCHEMA." />

    <!-- SMTP -->
    <add key="SmtpServer"  value="mail.emp-group.com" />

    <!-- JSON configuration files (relative to exe directory) -->
    <add key="mailConfigFilePath"  value="\statement\mailConfiguration.json" />
    <add key="pathConfiguration"   value="\statement\pathConfiguration.json" />

    <!-- Merchant statement MDB template (absolute path, configurable) -->
    <add key="MerchantMdbTemplatePath"
         value="D:\pC#\ProjData\Statement\_Data\MerchantStatementTemplate.mdb" />

  </appSettings>
</configuration>
