<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <AssemblyName>StatementFile.Infrastructure</AssemblyName>
    <RootNamespace>StatementFile.Infrastructure</RootNamespace>
    <Nullable>disable</Nullable>
    <LangVersion>10</LangVersion>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\StatementFile.Domain\StatementFile.Domain.csproj" />
    <ProjectReference Include="..\StatementFile.Application\StatementFile.Application.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- EF Core SQL Server provider -->
    <PackageReference Include="Microsoft.EntityFrameworkCore.SqlServer" Version="8.0.0" />
    <!-- EF Core design-time tools (migrations, scaffolding) -->
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="8.0.0">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>

    <!-- JSON configuration files -->
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />

    <!--
      System.Configuration.ConfigurationManager brings App.config support to .NET 8.
      AppConfigurationService reads SmtpServer, ServerName, MainSchema, etc. from it.
    -->
    <PackageReference Include="System.Configuration.ConfigurationManager" Version="8.0.0" />

    <!--
      Crystal Reports: must be referenced via legacy HintPath.
      Requires the SAP Crystal Reports runtime. Adjust path to match your installation.
    -->
    <Reference Include="CrystalDecisions.CrystalReports.Engine">
      <HintPath>..\..\..\libs\CrystalDecisions.CrystalReports.Engine.dll</HintPath>
    </Reference>
    <Reference Include="CrystalDecisions.Shared">
      <HintPath>..\..\..\libs\CrystalDecisions.Shared.dll</HintPath>
    </Reference>
  </ItemGroup>

</Project>
